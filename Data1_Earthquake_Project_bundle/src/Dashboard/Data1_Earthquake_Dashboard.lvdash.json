{
  "datasets": [
    {
      "name": "81e8044c",
      "displayName": "EarthQuake_Detail",
      "queryLines": [
        "select * from silver.earthquake_data_final"
      ],
      "catalog": "data1_earthquake_dev",
      "schema": "default"
    },
    {
      "name": "be03b069",
      "displayName": "EarthQuake_Type",
      "queryLines": [
        "SELECT\r\n",
        "    COUNT(*) AS total_magnitude_bucket,\r\n",
        "    magnitude_bucket\r\n",
        "FROM (\r\n",
        "    SELECT\r\n",
        "        CASE\r\n",
        "            WHEN CAST(mag AS DOUBLE) < 2 THEN 'Micro (<2)'\r\n",
        "            WHEN CAST(mag AS DOUBLE) BETWEEN 2 AND 3 THEN 'Minor (2-3)'\r\n",
        "            WHEN CAST(mag AS DOUBLE) BETWEEN 3 AND 4 THEN 'Light (3-4)'\r\n",
        "            ELSE 'Moderate+ (4+)'\r\n",
        "        END AS magnitude_bucket\r\n",
        "    FROM silver.earthquake_data\r\n",
        ") t\r\n",
        "GROUP BY magnitude_bucket;"
      ],
      "catalog": "data1_earthquake_dev",
      "schema": "default"
    },
    {
      "name": "d0c0e021",
      "displayName": "EarthQuake_Country",
      "queryLines": [
        "SELECT\r\n",
        "    COUNT(*) AS event_count,\r\n",
        "    CASE\r\n",
        "        WHEN size(split(place, ', ')) = 1 THEN split(place, ', ')[0]\r\n",
        "        ELSE split(place, ', ')[1]\r\n",
        "    END AS country\r\n",
        "FROM silver.earthquake_data_final\r\n",
        "GROUP BY country;"
      ],
      "catalog": "data1_earthquake_dev",
      "schema": "default"
    },
    {
      "name": "56efbb7d",
