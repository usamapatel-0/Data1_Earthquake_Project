{
  "datasets": [
    {
      "name": "f4b94980",
      "displayName": "earthquake_summary",
      "config": {
        "version": "1.1",
        "source": "data1_earthquake_dev.gold.earthquake_summary",
        "dimensions": [
          {
            "expr": "source.*"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    },
    {
      "name": "earthquake_main",
      "displayName": "Earthquake Data",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  data1_earthquake_dev.silver.earthquake_data_final"
      ],
      "catalog": "data1_earthquake_dev",
      "schema": "silver"
    },
    {
      "name": "top_locations",
      "displayName": "Top Earthquake Locations",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  data1_earthquake_dev.gold.top_locations\n",
        "ORDER BY\n",
        "  earthquake_count DESC\n",
        "LIMIT 20"
      ],
      "catalog": "data1_earthquake_dev",
      "schema": "gold"
    },
    {
      "name": "earthquake_daily",
      "displayName": "Daily Earthquake Trends",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  data1_earthquake_dev.gold.earthquake_daily\n",
        "ORDER BY\n",
        "  earthquake_date"
      ],
      "catalog": "data1_earthquake_dev",
      "schema": "gold"
    },
    {
      "name": "magnitude_distribution",
      "displayName": "Magnitude Distribution",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  data1_earthquake_dev.gold.magnitude_distribution"
      ],
      "catalog": "data1_earthquake_dev",
      "schema": "gold"
    },
    {
      "name": "earthquake_summary",
      "displayName": "Summary Statistics",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  data1_earthquake_dev.gold.earthquake_summary"
      ],
      "catalog": "data1_earthquake_dev",
      "schema": "gold"
    },
    {
      "name": "depth_analysis",
      "displayName": "Depth Analysis",
      "queryLines": [
        "SELECT\n",
        "  CASE\n",
        "    WHEN depth < 10 THEN 'Shallow (<10km)'\n",
        "    WHEN depth < 70 THEN 'Intermediate (10-70km)'\n",
        "    ELSE 'Deep (>70km)'\n",
        "  END AS depth_range,\n",
        "  COUNT(*) AS earthquake_count\n",
        "FROM\n",
        "  data1_earthquake_dev.silver.earthquake_data_final\n",
        "GROUP BY\n",
        "  depth_range\n",
        "ORDER BY\n",
        "  depth_range"
      ],
      "catalog": "data1_earthquake_dev",
      "schema": "silver"
    }
  ],
